<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>ShabatShalom</AssemblyName>
    <RootNamespace>ShabatShalom</RootNamespace>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>ShabatShalom</PackageId>
    <Version>1.0.0</Version>
    <Authors>edanick</Authors>
    <Description>A C# library for calculating Jewish prayer times (zmanim) and Shabbat times</Description>
    <Copyright>Copyright © 2024 edanick</Copyright>
    <License>GNU General Public License v3.0</License>
    <PackageLicenseExpression>GPL-3.0</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/edanick/shabat-shalom-cs</PackageProjectUrl>
    <RepositoryUrl>https://github.com/edanick/shabat-shalom-cs</RepositoryUrl>
    <PackageTags>jewish,zmanim,prayer,shabbat,hebrew,calendar</PackageTags>
  </PropertyGroup>

</Project>
